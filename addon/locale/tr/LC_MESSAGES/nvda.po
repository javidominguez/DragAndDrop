#: DragAndDrop/__init__.py:35
msgid "Drag and drop"
msgstr "Sürükle ve bırak"

#: DragAndDrop/__init__.py:48
#, python-format
msgid "Window in %d, %d. Width %d, height %d"
msgstr "Pencere içinde  %d, %d. genişlik %d, yükseklik %d"

#: DragAndDrop/__init__.py:52
msgid "without selection for drag and drop"
msgstr "sürükle ve bırak için seçilmemiş"

#: DragAndDrop/__init__.py:56
msgid " marked for drag and drop"
msgstr " Sürükle bırak için seçilmiş"

#: DragAndDrop/__init__.py:59
msgid "(inaccessible from here)"
msgstr "(buradan erişilemez)"

#: DragAndDrop/__init__.py:63
#, python-format
msgid "Mouse cursor is on %d, %d above "
msgstr "Fare imleci konumu %d, %d üzerinde "

#: DragAndDrop/__init__.py:68
msgid "(outside of the active window)"
msgstr "(etkin pencerenin dışında)"

#: DragAndDrop/__init__.py:70
msgid "Left button locked"
msgstr "Sol fare kilitli"

#: DragAndDrop/__init__.py:72
msgid "Right button locked"
msgstr "Sağ fare kilitli"

#: DragAndDrop/__init__.py:73
#, python-format
msgid "%s cursor"
msgstr "%s imleci"

#: DragAndDrop/__init__.py:75
msgid ""
"Reports on the position of the mouse cursor and the object to which it "
"points. Twice, reports on the marked object for drag and drop."
msgstr ""
"Fare imlecinin konumu ve üzerindeki nesne hakkında bilgi verir. İki kez "
"basıldığında, sürükleyip bırakmak üzere işaretlenmiş nesne hakkında bilgi "
"verir."

#: DragAndDrop/__init__.py:79
msgid "selection cancelled"
msgstr "seçim iptal edildi"

#: DragAndDrop/__init__.py:94
#, python-format
msgid "%s selected to drag"
msgstr "%s sürüklemek için seçildi"

#: DragAndDrop/__init__.py:97
msgid "Marks the object in navigator to be dragged."
msgstr "Nesne sunucusu konumundaki nesneyi sürüklemek için işaretler."

#: DragAndDrop/__init__.py:101
msgid "Nothing is selected for drag"
msgstr "Sürüklemek için seçim yok"

#: DragAndDrop/__init__.py:107
msgid "press space or arrows to drag and drop"
msgstr "sürükleyip bırakmak için ara çubuğu veya yön tuşlarına basın"

#: DragAndDrop/__init__.py:116
msgid ""
"Drags the selected object. Then press space, arrows or Enter to choose where "
"to drop it. "
msgstr ""
"Seçilen nesneyi sürükler. Ardından, nereye bırakacağınızı seçmek için "
"boşluk, yön veya Enter tuşuna basın. "

#: DragAndDrop/__init__.py:121
msgid "can't move it on himself"
msgstr "kendi konumuna taşınamaz"

#: DragAndDrop/__init__.py:126 DragAndDrop/__init__.py:140
#: DragAndDrop/__init__.py:151 DragAndDrop/__init__.py:162
#: DragAndDrop/__init__.py:173
msgid "Can't drop here"
msgstr "Buraya bırakılamıyor"

#: DragAndDrop/__init__.py:189
msgid "Cannot find the object marked."
msgstr "İşaretli nesne bulunamadı."

#: DragAndDrop/__init__.py:198 DragAndDrop/__init__.py:208
msgid "Can't move mouse pointer."
msgstr "Fare işaretçisi hareket ettirilemiyor."

#: DragAndDrop/__init__.py:201
#, python-format
msgid "click in %d, %d"
msgstr "%d, %d tıkla"

#: DragAndDrop/__init__.py:204
msgid "dragging"
msgstr "sürükleniyor"

#: DragAndDrop/__init__.py:212
#, python-format
msgid "moved to %d, %d"
msgstr "%d, %d konumuna taşındı"

#: DragAndDrop/__init__.py:219
msgid "dropped on "
msgstr "bırakıldı "

#: DragAndDrop/__init__.py:238
msgid "maximized"
msgstr "ekran kaplandı"

#: DragAndDrop/__init__.py:240
msgid "large"
msgstr "büyük"

#: DragAndDrop/__init__.py:242
msgid "medium"
msgstr "orta"

#: DragAndDrop/__init__.py:244
msgid "small"
msgstr "küçük"

#: DragAndDrop/__init__.py:246
msgid "very small"
msgstr "çok küçük"

#: DragAndDrop/__init__.py:249
msgid "centered"
msgstr "ortalı"

#: DragAndDrop/__init__.py:253
msgid "up"
msgstr "yukarı"

#: DragAndDrop/__init__.py:255
msgid "down"
msgstr "aşağı"

#: DragAndDrop/__init__.py:258
msgid "on left"
msgstr "solda"

#: DragAndDrop/__init__.py:260
